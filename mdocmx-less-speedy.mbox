Date: Mon, 19 Jan 2015 21:50:25 +0100
Subject: [PATCH 10/12] mdocmx(7): available only if $MDOCMX_ENABLE env-var set
 non-empty

---
 command.c | 18 +++++++++++++++++-
 less.nro  |  2 ++
 2 files changed, 19 insertions(+), 1 deletion(-)

diff --git a/command.c b/command.c
index 725b4a1..7411029 100644
--- a/command.c
+++ b/command.c
@@ -62,6 +62,7 @@ extern int same_pos_bell;
 extern int hilite_search;
 #endif
